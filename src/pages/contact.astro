---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact" sideBarActiveItemID="contact">
  <div class="max-w-2xl">
    <h1 class="text-3xl font-bold mb-6">Contact</h1>

    <p class="mb-4">
      Feel free to reach out to me at any of the following:
    </p>

    <div class="space-y-3">
      <div>
        <span class="font-semibold">Email:</span>
        <a href="mailto:shivamkataria1000@gmail.com" class="underline ml-2">
          shivamkataria1000@gmail.com
        </a>
      </div>

      <div>
        <span class="font-semibold">LinkedIn:</span>
        <a href="https://linkedin.com/in/shivam-kataria" target="_blank" class="underline ml-2">
          linkedin.com/in/shivam-kataria
        </a>
      </div>

      <div>
        <span class="font-semibold">GitHub:</span>
        <a href="https://github.com/Shivam-Kataria" target="_blank" class="underline ml-2">
          github.com/Shivam-Kataria
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
